# Local-only environment contract for Milestone 2 infrastructure.
# Copy this file to .env when later stages create compose.yaml.
# These are non-secret example values. Never put production credentials in this file.

COMPOSE_PROJECT_NAME=mall-rebuild

# MySQL
MYSQL_HOST_PORT=3306
MYSQL_DATABASE=mall
MYSQL_ROOT_USERNAME=root
MYSQL_ROOT_PASSWORD=local-only-mysql-root
MYSQL_MIGRATION_USERNAME=mall_migration
MYSQL_MIGRATION_PASSWORD=local-only-mysql-migration
MYSQL_ADMIN_USERNAME=mall_admin
MYSQL_ADMIN_PASSWORD=local-only-mysql-admin
MYSQL_PORTAL_USERNAME=mall_portal
MYSQL_PORTAL_PASSWORD=local-only-mysql-portal
MYSQL_SEARCH_USERNAME=mall_search
MYSQL_SEARCH_PASSWORD=local-only-mysql-search

# Redis
REDIS_HOST_PORT=6379
REDIS_PASSWORD=local-only-redis

# MongoDB
MONGO_HOST_PORT=27017
MONGO_DATABASE=mall_portal
MONGO_ROOT_USERNAME=mall_mongo_root
MONGO_ROOT_PASSWORD=local-only-mongo-root
MONGO_APP_USERNAME=mall_portal_app
MONGO_APP_PASSWORD=local-only-mongo-app
MONGO_PRODUCT_COLLECTION=member_product_collections
MONGO_BRAND_FOLLOW_COLLECTION=member_brand_follows
MONGO_READ_HISTORY_COLLECTION=member_read_history

# RabbitMQ
RABBITMQ_HOST_PORT=5672
RABBITMQ_MANAGEMENT_HOST_PORT=15672
RABBITMQ_VHOST=/mall
RABBITMQ_BOOTSTRAP_USERNAME=mall_local_admin
RABBITMQ_BOOTSTRAP_PASSWORD=local-only-rabbit-bootstrap
RABBITMQ_APP_USERNAME=mall_app
RABBITMQ_APP_PASSWORD=local-only-rabbit-app

# Elasticsearch
ELASTICSEARCH_HOST_PORT=9200

# MinIO
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_ROOT_USERNAME=mall_minio_root
MINIO_ROOT_PASSWORD=local-only-minio-root
MINIO_APP_USERNAME=mall_storage_app
MINIO_APP_PASSWORD=local-only-minio-app
MINIO_PRODUCT_BUCKET=mall-product
